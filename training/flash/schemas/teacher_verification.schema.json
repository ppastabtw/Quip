{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["verdicts"],
  "additionalProperties": false,
  "properties": {
    "verdicts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_id", "target_intentional", "meaning_preserved", "facts_preserved", "tone_preserved", "natural", "minimal", "accepted", "reason"],
        "additionalProperties": false,
        "properties": {
          "target_id": {"type": "string", "minLength": 1},
          "target_intentional": {"type": "boolean"},
          "meaning_preserved": {"type": "boolean"},
          "facts_preserved": {"type": "boolean"},
          "tone_preserved": {"type": "boolean"},
          "natural": {"type": "boolean"},
          "minimal": {"type": "boolean"},
          "accepted": {"type": "boolean"},
          "reason": {"type": "string"}
        }
      }
    }
  }
}
