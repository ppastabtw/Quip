FREESOLO_API_KEY=<your-api-key>
BACKBOARD_API_KEY=<your-api-key>

# Optional local adapter runtime overrides. Model and adapter artifacts remain ignored.
QUIP_MODEL_ADDR=127.0.0.1:1234
QUIP_BASE_MODEL_ID=mlx-community/Qwen3.5-4B-MLX-8bit
QUIP_GLOBAL_MODEL_ADDR=127.0.0.1:1235
QUIP_GLOBAL_MODEL_PRESET=4b
QUIP_APC_ENABLED=1
QUIP_STREAMING=true
QUIP_EARLY_EXIT_AGREEMENT=3
QUIP_DEMO_WARMUP_RUNS=3
